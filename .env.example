# OIAP PVM Verifier — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to git.

# ── Deployment ──────────────────────────────────────────────────────────────

# Deployer wallet private key (hex, with or without 0x prefix).
# This account must hold testnet tokens for transaction gas.
# Get tokens from: Paseo Faucet / Polkadot Hub Testnet faucet
PRIVATE_KEY=

# Paseo Polkadot Hub TestNet RPC endpoint (default shown below).
POLKADOT_HUB_TESTNET_RPC=https://eth-rpc-testnet.polkadot.io

# ── Post-deploy (fill in after running deploy scripts) ──────────────────────

# Address output by `bash scripts/deploy.sh testnet` (the PVM Rust verifier).
PVM_ADDRESS=

# Address output by `deploy-contracts.cjs` (the EVM registry — what users call).
# Also set as NEXT_PUBLIC_REGISTRY_ADDRESS in frontend/.env.local.
REGISTRY_ADDRESS=
