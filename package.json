{
  "name": "oiap-pvm-verifier",
  "version": "1.0.0",
  "description": "Cross-VM Groth16 verifier using Solidity + Rust (PVM).",
  "main": "index.js",
  "scripts": {
    "test": "npx hardhat test",
    "test:evm": "npx hardhat test",
    "build:frontend": "npm --prefix frontend run build",
    "lint:frontend": "npm --prefix frontend run lint",
    "build:prover-cli": "cargo build --manifest-path prover-cli/Cargo.toml",
    "build:pvm-verifier": "cargo build --manifest-path contracts/pvm_verifier/Cargo.toml --target wasm32-unknown-unknown --no-default-features",
    "build:pvm-zk-verifier": "bash -lc 'cd contracts/pvm_zk_verifier && cargo +nightly build --release -Z json-target-spec'",
    "bench": "npx hardhat run bench/run-bench.cjs",
    "bench:network:testnet": "npx hardhat run --network polkadotHubTestnet bench/run-bench-network.cjs",
    "bench:summary": "node bench/summarize.cjs",
    "bench:summary:network": "node bench/summarize.cjs --network",
    "check:all": "npm run test:evm && npm run lint:frontend && npm run build:frontend && npm run build:prover-cli && npm run build:pvm-verifier && npm run build:pvm-zk-verifier"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "hardhat": "^3.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "type": "module"
}
